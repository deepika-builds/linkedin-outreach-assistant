{
  "manifest_version": 3,
  "name": "LinkedIn Outreach Assistant",
  "version": "1.0.0",
  "description": "Generate personalized LinkedIn outreach messages powered by Claude AI",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },

  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["dist/content-main.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.anthropic.com/*",
    "https://api.github.com/*",
    "https://*/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["src/options/options.html"],
      "matches":   ["https://www.linkedin.com/*"]
    }
  ]
}
